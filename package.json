{
	"name": "monorepo",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"setup": "npm install",
		"dev": "concurrently --kill-others --raw \"npm run dev --prefix web\"",
		"build": "concurrently --raw \"npm run build --prefix web\"",
		"start": "concurrently --kill-others --raw",
		"lint": "concurrently --raw \"npm run lint --prefix web\""
	},
	"devDependencies": {
		"concurrently": "^10.0.3"
	},
	"workspaces": [
		"web"
	]
}
